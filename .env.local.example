# ─────────────────────────────────────────────────────────
# Jarvis OS — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.
#
#   cp .env.local.example .env.local
# ─────────────────────────────────────────────────────────

# ── OpenAI API Key ────────────────────────────────────────
# Required for AI responses. Get yours at: https://platform.openai.com/api-keys
#
# NEXT_PUBLIC_ prefix makes it available in the browser bundle.
# For production, use OPENAI_API_KEY (server-only) via a Route Handler instead.
# Desktop Electron builds can safely use NEXT_PUBLIC_ since the key stays local.
NEXT_PUBLIC_OPENAI_API_KEY=sk-...

# ── OpenAI Model (optional override) ─────────────────────
# Defaults to gpt-4o. Set to gpt-4o-mini for lower cost.
# NEXT_PUBLIC_OPENAI_MODEL=gpt-4o

# ── App Mode ──────────────────────────────────────────────
# web = browser only, electron = desktop app
NEXT_PUBLIC_APP_MODE=web

# ── Feature Flags ────────────────────────────────────────
# Set to "true" to enable experimental features
NEXT_PUBLIC_ENABLE_WAKE_WORD=false
NEXT_PUBLIC_ENABLE_MEMORY=true
NEXT_PUBLIC_ENABLE_TOOLS=true
